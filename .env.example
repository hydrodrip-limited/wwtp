# ─── MLflow ───────────────────────────────────────────────────────────────────
# URI for the MLflow tracking server. Use "file:./mlruns" for local file store,
# or a remote URI such as "http://mlflow-server:5000" for a shared deployment.
MLFLOW_TRACKING_URI=file:./mlruns

# Registered model name in the MLflow Model Registry.
MODEL_NAME=wwtp_effluent_predictor

# Model version to load at inference time. Use "latest" for the most recent.
MODEL_VERSION=latest

# ─── Data ─────────────────────────────────────────────────────────────────────
# Default target column. One of: DO_1, DO_2, DO_3, NO3, NH4
TARGET_COL=NH4

# Number of past timesteps used as the RNN input window.
LOOKBACK=8

# ─── Training ─────────────────────────────────────────────────────────────────
EPOCHS=50
BATCH_SIZE=100
SEED=42

# ─── Inference API (for api_client and streamlit app) ────────────────────────
# URL of the running MLflow model server.
API_URL=http://localhost:5000/invocations

# Timeout in seconds for HTTP requests to the prediction API.
API_TIMEOUT=30

# ─── Streamlit UI ─────────────────────────────────────────────────────────────
# Path to the fitted scalers .joblib file when running the UI without Docker.
# In Docker this is set automatically by the Dockerfile to /app/scalers.joblib.
SCALERS_PATH=wwtp_rnn_mlflow/wwtp_rnn_bundle/mlruns/248838729491991513/1ea0da5dd20549dea78db1770a219acb/artifacts/RNN_e50_b100_lb8_scalers.joblib

# ─── Logging ──────────────────────────────────────────────────────────────────
# "json" for structured JSON logs (production), "human" for readable output (dev).
LOG_FORMAT=human
LOG_LEVEL=INFO
